{% for event in collections.events %}
<div class="announcement-banner" data-event-date="{{ event.data.date | machineDate }}" style="display:none;">
  <div class="container">
    <a href="{{ '/events/' | url }}{{ event.fileSlug }}/" class="announcement-banner__link">
      <span class="announcement-banner__badge">Upcoming</span>
      <span class="announcement-banner__text">{{ event.data.title }} — {{ event.data.date | shortDate }}</span>
      <span class="announcement-banner__arrow">→</span>
    </a>
  </div>
</div>
{% endfor %}
